{
  "manifest_version": 2,
  "name": "Vernam Cipher",
  "version": "1.0.0",
  "description": "Encrypt and decrypt selected text using the Vernam (One-Time Pad) cipher.",
  "permissions": [
    "contextMenus",
    "activeTab",
    "storage",
    "clipboardWrite"
  ],
  "background": {
    "scripts": ["background.js"],
    "persistent": false
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["crypto/vernam.js", "content.js"]
    }
  ],
  "browser_action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "48": "icons/icon-48.png",
      "96": "icons/icon-96.png"
    },
    "default_title": "Vernam Cipher"
  },
  "icons": {
    "48": "icons/icon-48.png",
    "96": "icons/icon-96.png"
  }
}
